# Airflow stack config. Copy to .env (gitignored) and fill in. docker compose
# automatically reads this directory's .env for variable interpolation.
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=equities
DB_USER=dbt
DB_PASSWORD=your-dbt-role-password
DB_SSLMODE=require

S3_BUCKET=equities-analytics-raw-xxxxxxxx
AWS_REGION=us-east-1

ALPHA_VANTAGE_API_KEY=your-av-key
AV_REQUESTS_PER_MINUTE=5
AV_PRICES_FUNCTION=TIME_SERIES_DAILY
AV_PRICES_OUTPUTSIZE=compact

# Local dev only: host path to AWS credentials mounted into the containers.
# On EC2, delete the .aws volume mount and rely on the instance role instead.
HOST_AWS_DIR=/home/you/.aws
