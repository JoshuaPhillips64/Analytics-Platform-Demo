# Copy to .env (gitignored) for local EL runs. On EC2, AWS creds come from the
# instance role instead of a file. Never commit real secrets (golden rule #10).

# --- Alpha Vantage ---
ALPHA_VANTAGE_API_KEY=your-av-key
AV_REQUESTS_PER_MINUTE=5           # free tier = 5 (25/day cap); premium = 75
# Prices endpoint: free TIME_SERIES_DAILY (non-adjusted) or, with premium,
# TIME_SERIES_DAILY_ADJUSTED (adds adjusted_close/dividend/split).
AV_PRICES_FUNCTION=TIME_SERIES_DAILY
# "compact" = latest ~100 points (free); "full" = whole history (premium).
AV_PRICES_OUTPUTSIZE=compact

# --- S3 raw archive (from `terraform output -raw s3_raw_bucket`) ---
S3_BUCKET=equities-analytics-raw-xxxxxxxx
AWS_REGION=us-east-1

# --- RDS Postgres (from `terraform output`; password is the dbt role's) ---
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=equities
DB_USER=dbt
DB_PASSWORD=your-dbt-role-password
DB_SSLMODE=require
